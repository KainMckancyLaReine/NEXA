<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>NEXA — AI Employee Marketplace</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="assets/css/nexa.css" />
<style>
.mk-top { display: flex; align-items: center; justify-content: space-between; padding: 20px 32px; border-bottom: 1px solid var(--border); position: sticky; top: 0; background: rgba(255,255,255,0.8); backdrop-filter: blur(16px); z-index: 50; }
.mk-top .links { display: flex; gap: 22px; }
.mk-top .links a { color: var(--text-2); font-size: 14px; }
.mk-top .links a:hover { color: #fff; }
.mk-hero { padding: 132px 0 34px; text-align: center; }
.mk-hero h1 { font-size: clamp(2.2rem,5vw,3.6rem); letter-spacing: -.04em; }
.mk-hero p { color: var(--text-2); margin-top: 14px; font-size: 17px; }

.filters { display: flex; gap: 10px; justify-content: center; flex-wrap: wrap; margin: 28px 0 40px; }
.filters button { padding: 9px 18px; border-radius: 999px; border: 1px solid var(--border); background: rgba(15,23,42,0.02); color: var(--text-2); font-size: 13.5px; cursor: pointer; font-family: inherit; transition: .2s; }
.filters button.active { background: rgba(59,130,246,0.16); border-color: var(--accent); color: var(--accent-2); }

.mk-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 20px; padding-bottom: 80px; }
@media (max-width: 980px){ .mk-grid { grid-template-columns: repeat(2,1fr);} }
@media (max-width: 620px){ .mk-grid { grid-template-columns: 1fr;} }
.app-card { padding: 24px; display: flex; flex-direction: column; transition: transform .3s, border-color .3s; }
.app-card:hover { transform: translateY(-5px); border-color: var(--border-strong); }
.app-card .head { display: flex; align-items: center; gap: 14px; }
.app-card .av { width: 50px; height: 50px; border-radius: 14px; background: linear-gradient(135deg,#3B82F6,#1e40af); display: grid; place-items: center; font-weight: 700; font-size: 16px; box-shadow: 0 0 26px -6px var(--accent-glow); }
.app-card .name { font-weight: 700; font-size: 16px; }
.app-card .dept { font-size: 12px; color: var(--accent-2); }
.app-card .tag { color: var(--text-2); font-size: 13.5px; margin: 16px 0 14px; }
.skills { display: flex; flex-wrap: wrap; gap: 7px; margin-bottom: 18px; }
.skills span { font-size: 11.5px; padding: 5px 10px; border-radius: 999px; border: 1px solid var(--border); color: var(--text-3); }
.app-foot { margin-top: auto; display: flex; align-items: center; justify-content: space-between; gap: 12px; padding-top: 16px; border-top: 1px solid var(--border); }
.app-foot .price { font-size: 14px; color: var(--text-2); } .app-foot .price b { color: var(--text); font-weight: 700; font-size: 16px; }
.btn-install { padding: 10px 18px; font-size: 13.5px; }
.installed-badge { font-size: 12px; color: var(--success); display: flex; align-items: center; gap: 6px; font-weight: 600; }

.toast { position: fixed; bottom: 26px; left: 50%; transform: translateX(-50%) translateY(20px); opacity: 0; background: var(--card); border: 1px solid var(--accent); border-radius: 14px; padding: 14px 22px; font-size: 14px; box-shadow: var(--shadow-soft); z-index: 100; transition: .35s; }
.toast.show { opacity: 1; transform: translateX(-50%) translateY(0); }
.toast b { color: var(--accent-2); }
.api-flag { font-size: 12px; color: var(--text-3); text-align: center; padding: 0 0 30px; }
</style>
</head>
<body>
<div class="ambient"></div>
<div class="grid-overlay"></div>

<nav class="nav" id="nav">
  <a class="brand" href="index.html"><span class="logo"></span> NEXA</a>
  <div class="nav-links">
    <a href="platform.html" data-i18n="nav.platform">Platform</a>
    <a href="workforce.html" data-i18n="nav.workforce">Workforce</a>
    <a href="integrations.html" data-i18n="nav.integrations">Integrations</a>
    <a href="marketplace.html" style="color:var(--ink)" data-i18n="nav.marketplace">Marketplace</a>
    <a href="pricing.html" data-i18n="nav.pricing">Pricing</a>
  </div>
  <div class="nav-actions">
    <span data-lang-mount></span>
    <a href="onboarding.html" class="btn btn-primary" style="padding:11px 22px">Deploy Workforce</a>
  </div>
</nav>

<div class="container">
  <div class="mk-hero">
    <span class="eyebrow"><span class="dot"></span> Phase 3 · Workforce Marketplace</span>
    <h1 style="margin-top:20px">Install AI employees<br>like apps.</h1>
    <p>Browse specialized digital workers. One click hires them into your workforce — instantly operational.</p>
  </div>

  <div class="filters" id="filters"></div>
  <div class="mk-grid" id="grid"></div>
  <p class="api-flag" id="apiFlag"></p>
</div>

<div class="toast" id="toast"></div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
<script src="assets/js/api.js"></script>
<script>
const $ = s => document.querySelector(s);

// fallback library (used when API offline)
const FALLBACK = [
  { id:'OM', code:'OM', name:'AI Operations Manager', dept:'Operations', tagline:'Email · Scheduling · Reporting · CRM', skills:['Email','Scheduling','Reporting','CRM','Workflows'], price:499, installed:true },
  { id:'SM', code:'SM', name:'AI Sales Manager', dept:'Sales', tagline:'Lead qualification · Follow-up · Proposals', skills:['Leads','Follow-up','Proposals','Pipeline','CRM'], price:499, installed:true },
  { id:'FM', code:'FM', name:'AI Finance Manager', dept:'Finance', tagline:'Invoices · Reminders · Cashflow reports', skills:['Invoices','Reminders','Cashflow','Forecasting'], price:499, installed:false },
  { id:'SA', code:'SA', name:'AI Support Agent', dept:'Support', tagline:'Tickets · Customer comms · 24/7 support', skills:['Tickets','Comms','Knowledge base','24/7'], price:499, installed:false },
  { id:'RA', code:'RA', name:'AI Recruiting Agent', dept:'Recruiting', tagline:'Screening · Scheduling · Analytics', skills:['Screening','Scheduling','Analytics'], price:499, installed:false },
  { id:'DA', code:'DA', name:'AI Data Analyst', dept:'Operations', tagline:'Dashboards · Insights · Anomaly detection', skills:['Reporting','Trends','Anomalies','Forecasting'], price:499, installed:false },
  { id:'MM', code:'MM', name:'AI Marketing Manager', dept:'Marketing', tagline:'Campaigns · Content · Lead gen', skills:['Campaigns','Content','Lead gen','A/B testing'], price:499, installed:false },
  { id:'PM', code:'PM', name:'AI Procurement Manager', dept:'Operations', tagline:'Vendors · POs · Approvals', skills:['Vendors','POs','Approvals','Spend'], price:499, installed:false },
];

let items = [];
let filter = 'All';

function toast(html){ const t=$('#toast'); t.innerHTML=html; t.classList.add('show'); clearTimeout(t._t); t._t=setTimeout(()=>t.classList.remove('show'),2600); }

function render(){
  const grid = $('#grid'); grid.innerHTML='';
  const shown = items.filter(e => filter==='All' || e.dept===filter);
  shown.forEach(e => {
    const card = document.createElement('div');
    card.className='app-card glass';
    card.innerHTML = `
      <div class="head"><div class="av">${window.aiInitial?aiInitial(e.id):e.code}</div><div><div class="name">${(window.AINAMES&&AINAMES[e.id])||e.name}</div><div class="dept">${e.name.replace("AI ","")} · ${e.dept}</div></div></div>
      <div class="tag">${e.tagline}</div>
      <div class="skills">${e.skills.slice(0,5).map(s=>`<span>${s}</span>`).join('')}</div>
      <div class="app-foot">
        <div class="price"><b>€${e.price}</b><span style="color:var(--text-3)">/mo</span></div>
        ${e.installed
          ? `<span class="installed-badge">✓ Installed</span>`
          : `<button class="btn btn-primary btn-install" data-id="${e.id}">Install</button>`}
      </div>`;
    grid.appendChild(card);
  });
  grid.querySelectorAll('.btn-install').forEach(b => b.onclick = () => install(b.dataset.id));
  gsap.from('#grid .app-card', { opacity:0, y:24, duration:.5, stagger:.05, ease:'power3.out' });
}

async function install(id){
  const e = items.find(x=>x.id===id);
  if(NEXA.online){ await NEXA.install(id); }
  e.installed = true;
  toast(`<b>${e.name}</b> hired — now operational in your Command Center.`);
  render();
}

function buildFilters(){
  const depts = ['All', ...new Set(items.map(e=>e.dept))];
  const f = $('#filters'); f.innerHTML='';
  depts.forEach(d => { const b=document.createElement('button'); b.textContent=d; if(d===filter)b.classList.add('active'); b.onclick=()=>{filter=d; buildFilters(); render();}; f.appendChild(b); });
}

async function boot(){
  const data = await NEXA.marketplace();
  if(data && data.marketplace){ items = data.marketplace; $('#apiFlag').textContent='● Connected to live NEXA server — installs persist.'; }
  else { items = FALLBACK; $('#apiFlag').textContent='○ Demo mode — start the server (node server/server.js) to make installs persist.'; }
  buildFilters(); render();
}
const _nav=document.getElementById("nav"); addEventListener("scroll",()=>_nav.classList.toggle("scrolled",scrollY>40));
boot();
</script>
</body>
</html>

/* ---------- Morphing AI cores — only the two hero-scale cores morph shape ---------- */
(function morphCores(){
  const heroCores = [document.querySelector('#heroCore .core'), document.querySelector('.final .core')].filter(Boolean);
  heroCores.forEach((c, i) => {
    gsap.timeline({ repeat: -1, yoyo: true, defaults: { duration: 5 + i, ease: 'sine.inOut' } })
      .to(c, { borderRadius: '58% 42% 47% 53% / 50% 55% 45% 50%' })
      .to(c, { borderRadius: '45% 55% 60% 40% / 55% 45% 55% 45%' })
      .to(c, { borderRadius: '50%' });
  });
  // every other core just breathes via transform (cheap)
  gsap.utils.toArray('.ai-core .core').forEach((c, i) => {
    if(heroCores.includes(c)) return;
    gsap.to(c, { scale: 1.05, duration: 3 + i * 0.4, repeat: -1, yoyo: true, ease: 'sine.inOut' });
  });
})();


/* ---------- Workforce + pricing cards: 3D tilt on hover (pointer devices only) ---------- */
if(window.matchMedia('(hover: hover) and (pointer: fine)').matches){
  gsap.utils.toArray('.emp-card, .price-card').forEach(card => {
    let rafId = null;
    card.addEventListener('mousemove', e => {
      if(rafId) return;
      rafId = requestAnimationFrame(() => {
        const r = card.getBoundingClientRect();
        const px = (e.clientX - r.left) / r.width - 0.5;
        const py = (e.clientY - r.top) / r.height - 0.5;
        gsap.to(card, { rotationY: px * 6, rotationX: -py * 6, transformPerspective: 900, duration: 0.4, ease: 'power2.out' });
        rafId = null;
      });
    });
    card.addEventListener('mouseleave', () => gsap.to(card, { rotationY: 0, rotationX: 0, duration: 0.6, ease: 'power3.out' }));
  });
}


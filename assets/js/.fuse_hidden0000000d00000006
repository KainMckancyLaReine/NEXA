/* ---------- Particle network (hero) ---------- */
(function particles(){
  const canvas = document.getElementById('particles');
  if(!canvas) return;
  const ctx = canvas.getContext('2d', { alpha: true });
  const DPR = Math.min(window.devicePixelRatio || 1, 1.5);   // cap DPR — huge perf win on retina
  const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  let w, h, pts, raf, running = false, visible = true;
  const COUNT = reduce ? 0 : (window.innerWidth < 720 ? 22 : 46);   // far fewer nodes
  const MAXD = 110 * DPR, MAXD2 = MAXD * MAXD;                       // squared — skip sqrt
  function size(){ w = canvas.width = canvas.offsetWidth * DPR; h = canvas.height = canvas.offsetHeight * DPR; }
  function init(){
    size();
    pts = Array.from({length: COUNT}, () => ({
      x: Math.random()*w, y: Math.random()*h,
      vx: (Math.random()-.5)*0.22*DPR, vy: (Math.random()-.5)*0.22*DPR,
      r: (Math.random()*1.5+0.6)*DPR
    }));
  }
  function draw(){
    ctx.clearRect(0,0,w,h);
    for(let i=0;i<pts.length;i++){
      const p = pts[i];
      p.x+=p.vx; p.y+=p.vy;
      if(p.x<0||p.x>w) p.vx*=-1;
      if(p.y<0||p.y>h) p.vy*=-1;
      ctx.beginPath(); ctx.arc(p.x,p.y,p.r,0,Math.PI*2);
      ctx.fillStyle='rgba(180,150,255,0.5)'; ctx.fill();
      for(let j=i+1;j<pts.length;j++){
        const q = pts[j], dx=p.x-q.x, dy=p.y-q.y, d2=dx*dx+dy*dy;
        if(d2<MAXD2){
          const a = 0.16*(1-d2/MAXD2);
          ctx.beginPath(); ctx.moveTo(p.x,p.y); ctx.lineTo(q.x,q.y);
          ctx.strokeStyle='rgba(140,90,240,'+a+')'; ctx.lineWidth=DPR*0.55; ctx.stroke();
        }
      }
    }
    raf = requestAnimationFrame(draw);
  }
  function start(){ if(running || COUNT===0 || !visible) return; running=true; draw(); }
  function stop(){ running=false; cancelAnimationFrame(raf); }
  init();
  // only animate while the hero is actually on screen
  const hero = document.querySelector('.hero');
  if(hero && 'IntersectionObserver' in window){
    new IntersectionObserver(es => { visible = es[0].isIntersecting; visible ? start() : stop(); }, { threshold: 0.01 }).observe(hero);
  }
  start();
  document.addEventListener('visibilitychange', () => document.hidden ? stop() : start());
  let rt; window.addEventListener('resize', () => { clearTimeout(rt); rt = setTimeout(() => { stop(); init(); start(); }, 200); });
})();

/* ---------- Hero core orbiting nodes ---------- */
(function nodes(){
  const core = document.getElementById('heroCore');
  if(!core) return;
  const N = 6;
  for(let i=0;i<N;i++){
    const node = document.createElement('span');
    node.className='node';
    core.appendChild(node);
    const angle = (i/N)*Math.PI*2;
    const radius = 168;
    gsap.set(node, { x: Math.cos(angle)*radius, y: Math.sin(angle)*radius });
    gsap.to(node, {
      duration: 8 + i, repeat: -1, ease: 'none',
      onUpdate: function(){
        const t = this.progress()*Math.PI*2 + angle;
        gsap.set(node, { x: Math.cos(t)*radius, y: Math.sin(t)*radius });
      }
    });
  }
})();

/* ---------- Hero live ticker ---------- */
(function ticker(){
  const el = document.getElementById('heroTicker');
  if(!el) return;
  const items = [
    ['AI Operations Manager', 'processed 42 emails'],
    ['AI Sales Agent', 'followed up 17 leads'],
    ['AI Finance Agent', 'generated 8 invoices'],
    ['AI Support Agent', 'resolved 24 tickets'],
    ['AI Recruiter', 'screened 53 applicants'],
  ];
  let i = 0;
  function row(who, what){
    const t = new Date(Date.now() - Math.random()*40000).toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'});
    const div = document.createElement('div');
    div.className = 'ticker-row';
    div.innerHTML = `<span class="status-dot live"></span><span class="who">${who}</span><span class="what">${what}</span><span class="time">${t}</span>`;
    return div;
  }
  // seed 3
  for(let k=0;k<3;k++){ el.appendChild(row(...items[k])); }
  setInterval(() => {
    i = (i+1) % items.length;
    const node = row(...items[i]);
    node.style.opacity = 0;
    el.insertBefore(node, el.firstChild);
    gsap.to(node, { opacity:1, duration:.5 });
    if(el.children.length > 3){
      const last = el.lastElementChild;
      gsap.to(last, { opacity:0, height:0, duration:.4, onComplete: () => last.remove() });
    }
  }, 2600);
})();


/* ---------- SECTION 7: ROI calculator ---------- */
(function roi(){
  const emp = document.getElementById('rEmp'), sal = document.getElementById('rSal'), hrs = document.getElementById('rHrs');
  if(!emp) return;
  let industryF = 1.0;
  const seg = document.getElementById('industrySeg');
  seg.addEventListener('click', e => {
    if(e.target.tagName!=='BUTTON') return;
    seg.querySelectorAll('button').forEach(b=>b.classList.remove('active'));
    e.target.classList.add('active');
    industryF = parseFloat(e.target.dataset.f); calc();
  });
  const fmtEUR = n => '€' + Math.round(n).toLocaleString('en-US');
  const fmtNum = n => Math.round(n).toLocaleString('en-US');
  function animateTo(el, val, fmt){
    const cur = parseFloat(el.dataset._v || 0);
    gsap.to({v:cur}, { v:val, duration:.6, ease:'power2.out', onUpdate(){ el.textContent = fmt(this.targets()[0].v); }, onComplete(){ el.dataset._v = val; } });
  }
  function calc(){
    const E = +emp.value, S = +sal.value, H = +hrs.value;
    document.getElementById('vEmp').textContent = E;
    document.getElementById('vSal').textContent = fmtEUR(S);
    document.getElementById('vHrs').textContent = H;
    const hourly = S / 1880;
    const hoursYr = E * H * 46;                    // recoverable admin hours / yr
    const automatable = 0.62 * industryF;          // share NEXA absorbs
    const savings = hoursYr * hourly * automatable;
    const hoursRec = hoursYr * automatable;
    const prod = Math.min(95, Math.round(18 + H*1.6*industryF));
    const score = Math.min(99, Math.round(70 + automatable*40));
    animateTo(document.getElementById('oSave'), savings, fmtEUR);
    animateTo(document.getElementById('oHours'), hoursRec, fmtNum);
    document.getElementById('oProd').textContent = prod + '%';
    document.getElementById('oScore').textContent = score;
  }
  [emp,sal,hrs].forEach(r => r.addEventListener('input', calc));
  ScrollTrigger.create({ trigger:'#roi', start:'top 70%', once:true, onEnter: calc });
  calc();
})();


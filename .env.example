# ============================================================
# NEXA — environment configuration (copy to .env, never commit secrets)
# ============================================================
# Nothing here is required to run the demo. Set values to make
# auth, the AI engine, and connectors go LIVE.

# ---- Server ----
PORT=4000

# ---- Auth ----
# Signing secret for session tokens. Set this in production so tokens
# stay valid across restarts and deploys. If unset, a random per-install
# secret is generated and persisted in the data store.
NEXA_AUTH_SECRET=

# Admin account seeded on first run (overrides the demo defaults).
NEXA_ADMIN_USER=
NEXA_ADMIN_PASS=
NEXA_ADMIN_NAME=

# ---- Multi-tenancy & CORS ----
# Lock the API to your front-end origin in production (default '*').
NEXA_CORS_ORIGIN=
# Set to 'false' to disable self-serve tenant signup (/api/signup).
NEXA_ALLOW_SIGNUP=

# ---- AI engine (LLM) ----
# Set ONE of these to turn regex routing into real model-driven planning.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Optional model override (defaults: claude-sonnet-4-6 / gpt-4o-mini)
NEXA_LLM_MODEL=

# ---- Connector: Gmail (email.triage / email.send) ----
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ---- Connector: HubSpot (crm.listInactiveLeads / updateDeal / tickets) ----
# Private-app token from HubSpot → Settings → Integrations → Private Apps.
HUBSPOT_TOKEN=

# ---- Other connectors (sandbox until implemented like gmail/hubspot) ----
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REFRESH_TOKEN=
SF_CLIENT_ID=
SF_CLIENT_SECRET=
SF_REFRESH_TOKEN=
GCAL_CLIENT_ID=
GCAL_CLIENT_SECRET=
GCAL_REFRESH_TOKEN=
# ---- Connector: Exact Online (finance.listOverdue / createInvoice) ----
EXACT_CLIENT_ID=
EXACT_CLIENT_SECRET=
EXACT_REFRESH_TOKEN=
EXACT_DIVISION=
# Region base URL (default https://start.exactonline.nl)
EXACT_BASE=
